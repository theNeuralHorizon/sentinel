{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["bun"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowJs": false,
    "noEmit": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@sentinel/db": ["packages/db/src/index.ts"],
      "@sentinel/db/*": ["packages/db/src/*"],
      "@sentinel/shared": ["packages/shared/src/index.ts"],
      "@sentinel/shared/*": ["packages/shared/src/*"],
      "@sentinel/ai": ["packages/ai/src/index.ts"],
      "@sentinel/ai/*": ["packages/ai/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".svelte-kit", ".turbo"]
}

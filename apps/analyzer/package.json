{
  "name": "@sentinel/analyzer",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --external @anthropic-ai/sdk",

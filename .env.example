# === Core Services ===
NODE_ENV=development
LOG_LEVEL=info

# === API Gateway (Bun + Hono) ===
API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
API_JWT_SECRET=change-me-in-prod-min-32-chars-abcdef
API_JWT_EXPIRY=24h
API_RATE_LIMIT_PER_MIN=120

# === Scanner (Go) ===
SCANNER_HOST=0.0.0.0
SCANNER_PORT=4100
SCANNER_WORK_DIR=/tmp/sentinel-scans
SCANNER_MAX_CONCURRENT=8

# === Analyzer (Bun + AI) ===
ANALYZER_HOST=0.0.0.0
ANALYZER_PORT=4200
ANALYZER_BATCH_SIZE=10
ANALYZER_CONCURRENCY=4

# === Web (SvelteKit) ===
WEB_PORT=5173
PUBLIC_API_URL=http://localhost:4000
PUBLIC_WS_URL=ws://localhost:4000/ws

# === PostgreSQL + pgvector ===
DATABASE_URL=postgres://sentinel:sentinel@localhost:5432/sentinel
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# === Dragonfly (Redis-compatible) ===
REDIS_URL=redis://localhost:6379/0

# === NATS JetStream ===
NATS_URL=nats://localhost:4222
NATS_STREAM=sentinel-events
NATS_CONSUMER=sentinel-workers

# === n8n ===
N8N_URL=http://localhost:5678
N8N_API_KEY=change-me
N8N_WEBHOOK_BASE=http://localhost:5678/webhook

# === AI Providers ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIMENSIONS=1024

# === Vulnerability Sources ===
OSV_API_URL=https://api.osv.dev/v1
NVD_API_KEY=
GITHUB_ADVISORY_TOKEN=

# === Observability ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sentinel
PROMETHEUS_PORT=9464

# === Object Storage (for artifacts) ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=sentinel
S3_SECRET_KEY=sentinel-secret
S3_BUCKET=sentinel-artifacts
S3_REGION=us-east-1
